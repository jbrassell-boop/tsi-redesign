{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "tsi-redesign (npx serve)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npx", "serve", "."],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "tsi-redesign (python http.server)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
